<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AT Stock — บันทึกเบิก</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #080e1c;
  --surface:  #0f1829;
  --surface2: #162035;
  --border:   #1c2d47;
  --border2:  #243858;
  --text:     #dde6f5;
  --muted:    #4e6a8a;
  --blue:     #3d8ef0;
  --cyan:     #00c8d7;
  --green:    #12c98a;
  --yellow:   #f5a623;
  --red:      #f04444;
  --orange:   #f07040;
}

html, body {
  font-family: 'Sarabun', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
}

/* ─── BACKGROUND GRID ─── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(61,142,240,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(61,142,240,0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* ─── GLOW ORBS ─── */
body::after {
  content: '';
  position: fixed;
  top: -180px; left: -180px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(61,142,240,0.12) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ─── CARD ─── */
.card {
  position: relative;
  z-index: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 24px;
  width: 100%;
  max-width: 440px;
  overflow: hidden;
  box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(61,142,240,0.08);
  animation: fadeUp .4s ease both;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── HEADER ─── */
.header {
  padding: 32px 32px 24px;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(160deg, rgba(61,142,240,0.06) 0%, transparent 60%);
  text-align: center;
  position: relative;
}

.logo-wrap {
  width: 56px; height: 56px;
  background: linear-gradient(135deg, #1a3060, #0f1829);
  border: 1px solid var(--border2);
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  margin: 0 auto 14px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.app-title { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; }
.app-sub   { font-size: 12px; color: var(--muted); margin-top: 4px; }

/* ─── PIN SECTION ─── */
.pin-section { margin-top: 20px; }

.pin-dots {
  display: flex; gap: 12px;
  justify-content: center;
  margin-bottom: 14px;
}

.pin-dot {
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid var(--border2);
  transition: all .18s cubic-bezier(.34,1.56,.64,1);
}
.pin-dot.filled {
  background: var(--blue);
  border-color: var(--blue);
  transform: scale(1.2);
  box-shadow: 0 0 14px rgba(61,142,240,0.5);
}
.pin-dot.error {
  background: var(--red);
  border-color: var(--red);
  animation: shake .35s ease;
}

@keyframes shake {
  0%,100%{ transform:translateX(0); }
  25%     { transform:translateX(-4px); }
  75%     { transform:translateX(4px); }
}

.pin-label {
  font-size: 12px;
  color: var(--muted);
  min-height: 18px;
  transition: color .2s;
}
.pin-label.ok     { color: var(--green); }
.pin-label.wrong  { color: var(--red);   }

.pin-input-hidden {
  opacity: 0;
  position: absolute;
  width: 1px; height: 1px;
  pointer-events: none;
}

/* ─── BODY ─── */
.body { padding: 24px 28px 32px; }

/* ─── SECTION LABEL ─── */
.sec-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 14px;
  display: flex; align-items: center; gap: 8px;
}
.sec-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ─── FIELDS ─── */
.field { margin-bottom: 14px; }

.field-label {
  font-size: 11px;
  color: var(--muted);
  font-weight: 600;
  display: block;
  margin-bottom: 6px;
  letter-spacing: 0.4px;
}

.field-input {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 10px 14px;
  color: var(--text);
  font-size: 13px;
  font-family: 'Sarabun', sans-serif;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
}
.field-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(61,142,240,0.12);
}
.field-input::placeholder { color: var(--muted); }
.field-input:disabled { opacity: 0.45; cursor: not-allowed; }

select.field-input { appearance: none; cursor: pointer; }

/* ─── ITEM HINT ─── */
.item-hint {
  font-size: 12px;
  color: var(--cyan);
  font-family: 'IBM Plex Mono', monospace;
  font-weight: 500;
  min-height: 18px;
  margin: -6px 0 10px;
  padding: 0 2px;
  transition: opacity .2s;
}

/* ─── STOCK PILL ─── */
.stock-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 20px;
  margin-left: 6px;
  vertical-align: middle;
}
.stock-pill.ok  { background: rgba(18,201,138,0.12); color: var(--green); border: 1px solid rgba(18,201,138,0.25); }
.stock-pill.low { background: rgba(245,166,35,0.12);  color: var(--yellow); border: 1px solid rgba(245,166,35,0.25); }
.stock-pill.out { background: rgba(240,68,68,0.12);   color: var(--red);    border: 1px solid rgba(240,68,68,0.25); }

/* ─── DIVIDER ─── */
.divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

/* ─── SUBMIT BUTTON ─── */
.submit-btn {
  width: 100%;
  padding: 13px;
  border-radius: 12px;
  border: none;
  cursor: pointer;
  font-size: 15px;
  font-weight: 700;
  font-family: 'Sarabun', sans-serif;
  background: linear-gradient(135deg, var(--orange), var(--red));
  color: #fff;
  transition: opacity .2s, transform .15s;
  letter-spacing: 0.3px;
}
.submit-btn:not(:disabled):hover  { opacity: 0.88; transform: translateY(-1px); }
.submit-btn:not(:disabled):active { transform: translateY(0) scale(0.99); }
.submit-btn:disabled {
  background: var(--surface2);
  color: var(--muted);
  border: 1px solid var(--border2);
  cursor: not-allowed;
}

/* ─── LINK TO FULL APP ─── */
.full-link {
  text-align: center;
  margin-top: 18px;
  font-size: 12px;
  color: var(--muted);
}
.full-link a { color: var(--blue); text-decoration: none; }
.full-link a:hover { text-decoration: underline; }

/* ─── NOTIFICATION ─── */
#notif {
  position: fixed;
  top: 20px; right: 20px;
  padding: 12px 20px;
  border-radius: 12px;
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  font-family: 'Sarabun', sans-serif;
  z-index: 9999;
  display: none;
  max-width: 300px;
  box-shadow: 0 12px 32px rgba(0,0,0,0.5);
  animation: slideIn .25s ease;
}
@keyframes slideIn {
  from { opacity:0; transform: translateX(20px); }
  to   { opacity:1; transform: translateX(0); }
}

/* ─── MONTH BADGE ─── */
.month-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: rgba(61,142,240,0.1);
  border: 1px solid rgba(61,142,240,0.2);
  border-radius: 6px;
  padding: 2px 8px;
  font-size: 11px;
  color: var(--blue);
  font-weight: 600;
  margin-left: 8px;
  vertical-align: middle;
}
</style>
</head>
<body>

<div id="notif"></div>

<div class="card">
  <!-- HEADER + PIN -->
  <div class="header">
    <div class="logo-wrap">📦</div>
    <div class="app-title">AT Stock</div>
    <div class="app-sub">แผนกซ่อมบำรุง MT.FAC.AT</div>

    <div class="pin-section">
      <div class="pin-dots">
        <div class="pin-dot" id="d0"></div>
        <div class="pin-dot" id="d1"></div>
        <div class="pin-dot" id="d2"></div>
        <div class="pin-dot" id="d3"></div>
      </div>
      <input type="password" id="pin-hidden" class="pin-input-hidden" maxlength="4" inputmode="numeric" autocomplete="off">
      <div class="pin-label" id="pin-label">กรอก PIN 4 หลักเพื่อปลดล็อก</div>
    </div>
  </div>

  <!-- FORM BODY -->
  <div class="body">

    <div class="sec-label">ข้อมูลการเบิก</div>

    <!-- ผู้เบิก -->
    <div class="field">
      <label class="field-label">ชื่อผู้เบิก</label>
      <input class="field-input" id="f-by" placeholder="ระบุชื่อ-นามสกุล" disabled>
    </div>

    <!-- วันที่เบิก -->
    <div class="field">
      <label class="field-label">วันที่เบิกจริง</label>
      <input class="field-input" id="f-date" type="date" disabled>
    </div>

    <!-- รหัสอะไหล่ -->
    <div class="field">
      <label class="field-label">
        รหัสอะไหล่
        <span id="month-label" class="month-badge" style="display:none"></span>
      </label>
      <input class="field-input" id="f-id" list="item-datalist" placeholder="พิมพ์รหัสหรือชื่ออะไหล่..." disabled oninput="onItemInput()">
      <datalist id="item-datalist"></datalist>
      <div class="item-hint" id="item-hint"></div>
    </div>

    <!-- จำนวน -->
    <div class="field">
      <label class="field-label">จำนวนที่เบิก</label>
      <input class="field-input" id="f-qty" type="number" min="1" placeholder="0" disabled>
    </div>

    <!-- เหตุผล -->
    <div class="field">
      <label class="field-label">สาเหตุ / เหตุผลการเบิก</label>
      <input class="field-input" id="f-reason" placeholder="เช่น ซ่อม Motor ปั๊ม A, PM ประจำเดือน..." disabled>
    </div>

    <hr class="divider">

    <button class="submit-btn" id="submit-btn" disabled onclick="doSubmit()">
      🔒 ปลดล็อก PIN ก่อนบันทึก
    </button>

    <div class="full-link">
      <a href="javascript:void(0)" onclick="goFullApp()">เปิดระบบเต็ม Dashboard →</a>
    </div>

  </div>
</div>

<script>
// ================================================================
// CONFIG
// ================================================================
const GAS_URL  = '<?= ScriptApp.getService().getUrl() ?>';
const PASSWORD = '1234'; // เปลี่ยนได้

// ================================================================
// STATE
// ================================================================
let pinVal    = '';
let unlocked  = false;
let products  = [];
let isSaving  = false;
let currentMonth = new Date().getMonth(); // 0-based index สำหรับ months[]

const MONTH_TH = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
const MONTH_FULL = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];

// ================================================================
// PIN LOGIC
// ================================================================
function updateDots() {
  for (let i = 0; i < 4; i++) {
    const dot = document.getElementById('d' + i);
    dot.className = 'pin-dot' + (i < pinVal.length ? ' filled' : '');
  }
}

function checkPin() {
  if (pinVal === PASSWORD) {
    unlocked = true;
    document.getElementById('pin-label').className = 'pin-label ok';
    document.getElementById('pin-label').textContent = 'ปลดล็อกแล้ว ✓';
    enableForm();
    loadProducts();
  } else {
    const dots = document.querySelectorAll('.pin-dot');
    dots.forEach(d => d.className = 'pin-dot error');
    document.getElementById('pin-label').className = 'pin-label wrong';
    document.getElementById('pin-label').textContent = 'PIN ไม่ถูกต้อง!';
    pinVal = '';
    setTimeout(() => {
      updateDots();
      document.getElementById('pin-label').className = 'pin-label';
      document.getElementById('pin-label').textContent = 'กรอก PIN 4 หลักเพื่อปลดล็อก';
    }, 1400);
  }
}

function enableForm() {
  ['f-by','f-date','f-id','f-qty','f-reason'].forEach(id => {
    document.getElementById(id).disabled = false;
  });
  const btn = document.getElementById('submit-btn');
  btn.disabled = false;
  btn.textContent = '✅ ยืนยันการเบิก';
  // set today
  const today = new Date();
  document.getElementById('f-date').value = today.toISOString().split('T')[0];
  // แสดงเดือนปัจจุบัน
  const ml = document.getElementById('month-label');
  ml.style.display = 'inline-flex';
  ml.textContent = 'เดือน ' + MONTH_TH[currentMonth];
}

// ─── PIN input — ใช้ hidden input เป็นทางเดียว ป้องกัน double event ───
const pinInput = document.getElementById('pin-hidden');

// focus เมื่อคลิกการ์ด
document.querySelector('.card').addEventListener('click', () => {
  if (!unlocked) pinInput.focus();
});

// auto-focus ตอนโหลด
pinInput.focus();

// รับ input จาก hidden field (ทั้ง desktop + mobile)
pinInput.addEventListener('input', () => {
  if (unlocked) return;
  const digits = pinInput.value.replace(/\D/g, '');
  pinInput.value = ''; // เคลียร์ทันทีเสมอ
  for (const ch of digits) {
    if (pinVal.length < 4) {
      pinVal += ch;
      updateDots();
      if (pinVal.length === 4) { checkPin(); return; }
    }
  }
});

// Backspace สำหรับ desktop (ไม่ trigger input event)
pinInput.addEventListener('keydown', e => {
  if (unlocked) return;
  if (e.key === 'Backspace') {
    e.preventDefault();
    pinVal = pinVal.slice(0, -1);
    updateDots();
  }
});

// ================================================================
// LOAD PRODUCTS FROM GAS
// ================================================================
async function loadProducts() {
  try {
    // ใน GAS environment ใช้ google.script.run
    // ใน standalone web ใช้ fetch
    if (typeof google !== 'undefined' && google.script) {
      google.script.run
        .withSuccessHandler(onDataLoaded)
        .withFailureHandler(err => showNotif('❌ โหลดข้อมูลล้มเหลว', 'var(--red)'))
        .getAppData();
    } else {
      // fallback fetch (สำหรับ test นอก GAS)
      const res = await fetch(GAS_URL);
      const data = await res.json();
      onDataLoaded(data);
    }
  } catch(e) {
    showNotif('❌ โหลดข้อมูลล้มเหลว', 'var(--red)');
  }
}

function onDataLoaded(data) {
  products = data.products || [];
  buildDatalist();
  showNotif('✅ โหลดข้อมูล ' + products.length + ' รายการ', 'var(--green)');
}

function buildDatalist() {
  const dl = document.getElementById('item-datalist');
  dl.innerHTML = products.map(p => `<option value="${esc(p.id)}">${esc(p.name)}</option>`).join('');
}

// ================================================================
// ITEM HINT (แสดงสต็อกเดือนปัจจุบัน)
// ================================================================
function onItemInput() {
  const val = document.getElementById('f-id').value.trim().toLowerCase();
  const p = products.find(x => x.id.toLowerCase() === val || x.name.toLowerCase() === val);
  const hint = document.getElementById('item-hint');
  if (!p) { hint.innerHTML = ''; return; }

  const m = p.months && p.months[currentMonth];
  const stock = m ? m.bal : (p.opening || 0);
  const min   = p.minStock || 0;
  
  let pillClass = stock <= 0 ? 'out' : stock < min ? 'low' : 'ok';
  let pillText  = stock <= 0 ? 'หมดสต็อก' : stock < min ? 'ใกล้หมด' : 'ปกติ';

  hint.innerHTML = `
    <span style="color:var(--text)">${esc(p.name)}</span>
    <span class="stock-pill ${pillClass}">${stock} ${esc(p.unit)} · ${pillText}</span>
  `;
}

// ================================================================
// SUBMIT → saveData() ใน GAS
// ================================================================
async function doSubmit() {
  if (!unlocked || isSaving) return;

  const byVal     = document.getElementById('f-by').value.trim();
  const dateVal   = document.getElementById('f-date').value;
  const idVal     = document.getElementById('f-id').value.trim();
  const qtyVal    = parseInt(document.getElementById('f-qty').value);
  const reasonVal = document.getElementById('f-reason').value.trim();

  // ─── VALIDATE ───
  if (!byVal)               { showNotif('⚠️ กรุณาระบุชื่อผู้เบิก', 'var(--yellow)'); return; }
  if (!dateVal)             { showNotif('⚠️ กรุณาเลือกวันที่', 'var(--yellow)'); return; }
  if (!idVal)               { showNotif('⚠️ กรุณาระบุรหัสอะไหล่', 'var(--yellow)'); return; }
  if (!qtyVal || qtyVal<=0) { showNotif('⚠️ กรุณาระบุจำนวน', 'var(--yellow)'); return; }
  if (!reasonVal)           { showNotif('⚠️ กรุณาระบุสาเหตุการเบิก', 'var(--yellow)'); return; }

  const product = products.find(x => x.id.toLowerCase() === idVal.toLowerCase());
  if (!product) { showNotif('❌ ไม่พบรหัสอะไหล่ในระบบ', 'var(--red)'); return; }

  const m = product.months && product.months[currentMonth];
  const currentStock = m ? m.bal : (product.opening || 0);
  if (qtyVal > currentStock) {
    showNotif(`❌ สต็อกไม่พอ (คงเหลือ ${currentStock} ${product.unit})`, 'var(--red)');
    return;
  }

  // ─── BUILD PAYLOAD ───
  // คำนวณ column ของ OUT สำหรับเดือนนี้ใน sheet
  // โครงสร้าง: col 10 = col A (1-based)
  // col ของ OUT เดือน m = 10 + (m * 3) + 1  → (1-based col index ใน sheet)
  const outColIdx = 10 + (currentMonth * 3) + 1; // col OUT ของเดือนนี้

  const newOut = (m ? m.out : 0) + qtyVal;
  const newBal = currentStock - qtyVal;

  const updates = [
    { row: product.rowIdx, col: outColIdx,     val: newOut },
    { row: product.rowIdx, col: outColIdx + 1, val: newBal }  // bal = out+1
  ];

  // ─── FORMAT DATE ───
  const d = new Date(dateVal);
  const dateFormatted = `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()+543}`;

  const logEntry = {
    date:      dateFormatted,
    by:        byVal,
    id:        product.id,
    name:      product.name,
    monthName: MONTH_FULL[currentMonth] + ' ' + (new Date().getFullYear() + 543),
    qty:       qtyVal,
    reason:    reasonVal
  };

  // ─── SEND ───
  isSaving = true;
  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.textContent = '⏳ กำลังบันทึก...';

  if (typeof google !== 'undefined' && google.script) {
    google.script.run
      .withSuccessHandler(res => {
        onSaveSuccess(res, product, qtyVal);
      })
      .withFailureHandler(err => {
        showNotif('❌ บันทึกล้มเหลว: ' + err.message, 'var(--red)');
        resetBtn();
      })
      .saveData(updates, [logEntry]);
  } else {
    // mock สำหรับ test นอก GAS
    setTimeout(() => onSaveSuccess({ ok: true }, product, qtyVal), 1000);
  }
}

function onSaveSuccess(res, product, qty) {
  if (res && res.ok === false) {
    showNotif('❌ ' + (res.msg || 'บันทึกล้มเหลว'), 'var(--red)');
    resetBtn();
    return;
  }
  // อัปเดต local state
  const m = product.months[currentMonth];
  if (m) { m.out += qty; m.bal -= qty; }

  showNotif('✅ บันทึกสำเร็จ! ส่ง Telegram แล้ว 🚀', 'var(--green)');
  clearForm();
  resetBtn();
  isSaving = false;
}

function clearForm() {
  document.getElementById('f-id').value     = '';
  document.getElementById('f-qty').value    = '';
  document.getElementById('f-reason').value = '';
  document.getElementById('item-hint').innerHTML = '';
}

function resetBtn() {
  isSaving = false;
  const btn = document.getElementById('submit-btn');
  btn.disabled = false;
  btn.textContent = '✅ ยืนยันการเบิก';
}

// ================================================================
// NAVIGATE TO FULL APP
// ================================================================
function goFullApp() {
  if (typeof google !== 'undefined' && google.script) {
    window.top.location.href = GAS_URL;
  }
}

// ================================================================
// HELPERS
// ================================================================
function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function showNotif(msg, color) {
  const n = document.getElementById('notif');
  n.textContent  = msg;
  n.style.background = color || 'var(--green)';
  n.style.display    = 'block';
  clearTimeout(n._timer);
  n._timer = setTimeout(() => n.style.display = 'none', 3500);
}
</script>
